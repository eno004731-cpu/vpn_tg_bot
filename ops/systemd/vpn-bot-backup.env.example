BACKUP_TIMEZONE=Europe/Moscow
BACKUP_ROOT=/srv/backups/vpn-bot
APP_DIR=/opt/vpn-bot
SECRETS_FILE=/opt/vpn-bot/secrets/runtime.toml
SQLITE_DB=/opt/vpn-bot/data/bot.sqlite3
VPN_BOT_SYSTEMD=/etc/systemd/system/vpn-bot.service
VPN_BOT_ENV_FILE=/etc/default/vpn-bot
XUI_SYSTEMD=/etc/systemd/system/x-ui.service
XUI_HOME=/usr/local/x-ui
XUI_DATA_DIR=/etc/x-ui
K3S_CONFIG_DIR=/etc/rancher/k3s
K3S_MANIFESTS_DIR=/var/lib/rancher/k3s/server/manifests
CERT_DIRS="/root/cert /etc/letsencrypt"
RETENTION_DAILY=14
RETENTION_WEEKLY=8
